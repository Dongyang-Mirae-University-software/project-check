# SilverBridge AI - 백엔드 통합 환경 설정
# 이 파일을 .env 또는 .env.local로 복사해서 사용하세요

# ==================== Java 백엔드 API ====================
# Java Spring Boot 백엔드 서버 URL (사용자 관리, FCM 알림)
JAVA_API_URL=http://localhost:8080

# ==================== FastAPI 팀원 서버 ====================
# 팀원 FastAPI 서버 URL (라이브 스트림, AI 분석)
FASTAPI_URL=https://testai.gosky.kr

# FastAPI API Key
FASTAPI_API_KEY=silverbridge_live_7X9Dm4kaLdRHy

# FastAPI Session ID (스트림 세션)
FASTAPI_SESSION_ID=stream_001

# FastAPI Camera ID
FASTAPI_CAMERA_ID=ipad-room-001

# API 호출 타임아웃 (초)
API_TIMEOUT=30

# ==================== 감지 설정 ====================
# 감지 신뢰도 임계값 (0.0 ~ 1.0)
# 낮을수록 감지 민감하지만 오감지 증가, 높을수록 정확하지만 미감지 증가
# 권장값: 0.3 (원래 0.5는 너무 높음)
DETECTION_CONF=0.3

# 감지 결과 자동 보고 여부
# true: 감지 시 자동으로 로컬 JSONL 저장 + 보호자 알림
# false: 수동으로 report_detection() 호출
AUTO_REPORT=true

# ==================== 모델 경로 ====================
# (config.py에서 자동으로 설정되므로 여기선 필요 없음)
# FIRE_MODEL_PATH=models/fire_100ep/weights/best.pt
# KNIFE_MODEL_PATH=models/knife_500ep/weights/best.pt

# ==================== FCM (Firebase Cloud Messaging) ====================
# (향후 구현 - 현재 백엔드에서 처리)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY_ID=your-key-id
# FIREBASE_PRIVATE_KEY=your-private-key

# ==================== 개발 환경 ====================
# DEBUG=true
# LOG_LEVEL=DEBUG
